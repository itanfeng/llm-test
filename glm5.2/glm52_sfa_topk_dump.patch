+_LIGHTNING_DUMP_COUNT = 0
+_LIGHTNING_DUMP_LAYERS = {0, 1, 2, 6, 10, 14, 30, 34, 38, 66, 70, 74}
+_LIGHTNING_DUMP_SEEN = set()
+
+print(f"[GLM52_DUMP] patch loaded: {__file__}", flush=True)
+
+
+def _dump_lightning_indexer_call(
+    sfa_impl,
+    attn_metadata,
+    operator: str,
+    inputs: dict[str, Any],
+    outputs: dict[str, Any],
+    attrs: dict[str, Any],
+) -> None:
+    """Save one complete DecodeOnly lightning-indexer invocation."""
+    if sfa_impl.tp_rank != int(os.getenv("GLM52_TOPK_TP_RANK", "0")):
+        return
+
+    layer_name = sfa_impl.layer_name or "unknown_layer"
+    state_name = getattr(attn_metadata.attn_state, "name", str(attn_metadata.attn_state))
+    selected = any(f".layers.{index}." in f".{layer_name}." for index in _LIGHTNING_DUMP_LAYERS)
+    seen_key = (layer_name, state_name)
+    if seen_key not in _LIGHTNING_DUMP_SEEN:
+        _LIGHTNING_DUMP_SEEN.add(seen_key)
+        print(
+            f"[GLM52_DUMP] hook: layer={layer_name} state={state_name} selected={selected}",
+            flush=True,
+        )
+    if state_name != "DecodeOnly" or not selected:
+        return
+
+    def to_cpu(value):
+        if isinstance(value, torch.Tensor):
+            return value.detach().to(device="cpu", non_blocking=False)
+        return value
+
+    global _LIGHTNING_DUMP_COUNT
+    dump_index = _LIGHTNING_DUMP_COUNT
+    _LIGHTNING_DUMP_COUNT += 1
+
+    dump_dir = os.getenv("GLM52_TOPK_DIR", "pt")
+    os.makedirs(dump_dir, exist_ok=True)
+    safe_layer = "".join(char if char.isalnum() or char in "._-" else "_" for char in layer_name)
+    path = os.path.join(
+        dump_dir,
+        f"lightning_indexer_pid{os.getpid()}_tp{sfa_impl.tp_rank}_"
+        f"{safe_layer}_dump{dump_index:06d}.pt",
+    )
+    temporary_path = f"{path}.tmp"
+    torch.save(
+        {
+            "operator": operator,
+            "inputs": {name: to_cpu(value) for name, value in inputs.items()},
+            "outputs": {name: to_cpu(value) for name, value in outputs.items()},
+            "attrs": attrs,
+            "layer_name": layer_name,
+            "dump_index": dump_index,
+            "pid": os.getpid(),
+            "tp_rank": sfa_impl.tp_rank,
+        },
+        temporary_path,
+    )
+    os.replace(temporary_path, path)
+    print(f"[GLM52_DUMP] saved: {path} layer={layer_name} dump_index={dump_index}", flush=True)
+
